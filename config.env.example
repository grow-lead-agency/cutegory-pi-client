# =============================================================================
# Cutegory PiCast — Configuration
# Copy to config.env and fill in values: cp config.env.example config.env
# =============================================================================

# ---------- Required ----------

# Backoffice API
SERVER_URL="https://backoffice.cutegory.cz"
DEVICE_ID=""          # UUID from backoffice device registration
DEVICE_KEY=""         # Secret device token (X-Device-Token header)

# ---------- Optional (defaults are fine) ----------

# R2 Media CDN
R2_BASE_URL="https://signage-media.cutegory.cz"

# Polling
POLL_INTERVAL=30      # seconds between sync polls

# Local storage
MEDIA_DIR="/opt/picast/media"
LOG_DIR="/opt/picast/logs"

# Player
PLAYER_BIN="mpv"
FULLSCREEN=true

# Display control (CEC for TVs, DDC/CI for monitors)
CEC_ENABLED=true
CEC_DEVICE=0          # TV HDMI port (0 = auto)
# FORCE_RESOLUTION=""   # Override auto-detect, e.g. "3840x2160@60"

# Auto-update from GitHub (public repo)
GITHUB_REPO="grow-lead-agency/cutegory-pi-client"
GITHUB_BRANCH="main"
